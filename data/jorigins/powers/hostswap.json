{
  "name": "Corpse Host",
  "description": "You can switch bodies into a different type of humanoid zombie. (Husk, Drowned or Zombie). This can include Baby Zombies.",
  "type": "origins:multiple",
  "swap_host": {
    "type": "origins:action_on_entity_use",
    "bientity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:if_else",
          "condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:nbt",
              "nbt": "{IsBaby:1b}"
            }
          },
          "if_action": {
            "type": "origins:actor_action",
            "action": {
              "type": "origins:execute_command",
              "command": "function jorigins:sethostbody_baby"
            }
          },
          "else_action": {
            "type": "origins:actor_action",
            "action": {
              "type": "origins:execute_command",
              "command": "scale reset @s"
            }
          }
        },
        {
          "type": "origins:target_action",
          "action": {
            "type": "origins:execute_command",
            "command": "function jorigins:damage_item"
          }
        },
        {
          "type": "origins:target_action",
          "action": {
            "type": "origins:execute_command",
            "command": "power grant @s jorigins:entity/dropinventory"
          }
        },
        {
          "type": "origins:target_action",
          "action": {
            "type": "origins:damage",
            "amount": 20,
            "damage_type": "minecraft:magic"
          }
        },
        {
          "type": "origins:if_else_list",
          "actions": [
            {
              "condition": {
                "type": "origins:target_condition",
                "condition": {
                  "type": "origins:entity_type",
                  "entity_type": "minecraft:husk"
                }
              },
              "action": {
                "type": "origins:actor_action",
                "action": {
                  "type": "origins:execute_command",
                  "command": "origin set @s origins:origin jorigins:vessel_husk"
                }
              }
            },
            {
              "condition": {
                "type": "origins:target_condition",
                "condition": {
                  "type": "origins:entity_type",
                  "entity_type": "minecraft:drowned"
                }
              },
              "action": {
                "type": "origins:actor_action",
                "action": {
                  "type": "origins:execute_command",
                  "command": "origin set @s origins:origin jorigins:vessel_drowned"
                }
              }
            },
            {
              "condition": {
                "type": "origins:target_condition",
                "condition": {
                  "type": "origins:entity_type",
                  "entity_type": "minecraft:zombie"
                }
              },
              "action": {
                "type": "origins:actor_action",
                "action": {
                  "type": "origins:execute_command",
                  "command": "origin set @s origins:origin jorigins:vessel_zombie"
                }
              }
            }
          ]
        },
        {
          "type": "origins:actor_action",
          "action": {
            "type": "origins:execute_command",
            "command": "attribute @s minecraft:generic.max_health base set 6"
          }
        },
        {
          "type": "origins:actor_action",
          "action": {
            "type": "origins:delay",
            "ticks": 5,
            "action": {
              "type": "origins:execute_command",
              "command": "attribute @s minecraft:generic.max_health base set 20"
            }
          }
        },
        {
          "type": "origins:actor_action",
          "action": {
            "type": "origins:trigger_cooldown",
            "power": "jorigins:hostswap_cooldown"
          }
        }
      ]
    },
    "bientity_condition": {
      "type": "origins:target_condition",
      "condition": {
        "type": "origins:in_tag",
        "tag": "jorigins:hostable"
      }
    },
    "item_condition": {
      "type": "origins:empty"
    },
    "hands": ["main_hand"],
    "condition": {
      "type": "origins:resource",
      "resource": "jorigins:hostswap_cooldown",
      "comparison": "==",
      "compare_to": 0
    }
  },
  "callback": {
    "type": "origins:action_on_callback",
    "entity_action_respawned": {
      "type": "origins:choice",
      "actions": [
        {
          "element": {
            "type": "origins:execute_command",
            "command": "scale reset @s"
          },
          "weight": 19
        },
        {
          "element": {
            "type": "origins:execute_command",
            "command": "function jorigins:sethostbody_baby"
          },
          "weight": 1
        }
      ]
    },
    "execute_chosen_when_orb": false
  },
  "cooldown": {
    "type": "origins:cooldown",
    "cooldown": 200,
    "hud_render": {
      "should_render": false,
      "bar_index": 3
    }
  }
}
