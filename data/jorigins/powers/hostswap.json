{
  "name": "Corpse Host",
  "description": "You can switch bodies into a different type of humanoid zombie. (Husk, Drowned or Zombie). This can include Baby Zombies.",
  "type": "origins:multiple",
  "drowned": {
    "type": "origins:action_on_entity_use",
    "bientity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:if_else",
          "condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:nbt",
              "nbt": "{IsBaby:1b}"
            }
          },
          "if_action": {
            "type": "origins:actor_action",
            "action": {
              "type": "origins:execute_command",
              "command": "function jorigins:setbaby"
            }
          },
          "else_action": {
            "type": "origins:actor_action",
            "action": {
              "type": "origins:execute_command",
              "command": "scale reset @s"
            }
          }
        },
        {
          "type": "origins:target_action",
          "action": {
            "type": "origins:damage",
            "amount": 20,
            "damage_type": "minecraft:magic"
          }
        },
        {
          "type": "origins:actor_action",
          "action": {
            "type": "origins:execute_command",
            "command": "origin set @s origins:origin jorigins:vessel_drowned"
          }
        }
      ]
    },
    "bientity_condition": {
      "type": "origins:target_condition",
      "condition": {
        "type": "origins:entity_type",
        "entity_type": "minecraft:drowned"
      }
    },
    "item_condition": {
      "type": "origins:empty"
    },
    "hands": ["main_hand"],
    "condition": {
      "type": "origins:or",
      "conditions": [
        {
          "type": "origins:origin",
          "origin": "jorigins:vessel_husk"
        },
        {
          "type": "origins:origin",
          "origin": "jorigins:vessel_zombie"
        }
      ]
    }
  },
