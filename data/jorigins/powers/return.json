{
  "name": "Familiar with Death",
  "description": "You're able to survive a deathly encounter, returning to a previous location instead. This weakens your control of your body for some time afterwards until you recover. \n Additionally, you can store your experiences in a bottle format, saving some of it in the event you do die.",
  "type": "origins:multiple",
  "setpoint": {
    "type": "origins:active_self",
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "function jorigins:savecoords"
        }
      ]
    },
    "cooldown": 20,
    "hud_render": {
      "should_render": false
    },
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:on_block"
        },
        {
          "type": "origins:dimension",
          "dimension": "minecraft:overworld"
        },
        {
          "type": "origins:moving",
          "inverted": true
        }
      ]
    }
  },
  "liferesource": {
    "type": "origins:resource",
    "min": 0,
    "max": 1,
    "start_value": 1,
    "hud_render": {
      "should_render": false
    }
  },
  "preventdeath": {
    "type": "origins:prevent_death",
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:clear_effect"
        },
        {
          "type": "origins:execute_command",
          "command": "execute as @s run function jorigins:tp with storage minecraft:teleport_position co_ords"
        },
        {
          "type": "origins:change_resource",
          "resource": "jorigins:return_liferesource",
          "change": -1
        },
        {
          "type": "origins:trigger_cooldown",
          "power": "jorigins:return_returncooldown"
        },
        {
          "type": "origins:delay",
          "ticks": 10,
          "action": {
            "type": "origins:apply_effect",
            "effect": {
              "id": "minecraft:instant_damage",
              "amplifier": 2,
              "duration": 1
            }
          }
        }
      ]
    },
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:resource",
          "resource": "jorigins:return_liferesource",
          "comparison": "==",
          "compare_to": 1
        },
        {
          "type": "origins:inventory",
          "process_mode": "items",
          "item_condition": {
            "type": "origins:ingredient",
            "ingredient": {
              "item": "minecraft:totem_of_undying"
            }
          },
          "comparison": "==",
          "compare_to": 0
        }
      ]
    }
  },
  "reset": {
    "type": "origins:action_on_callback",
    "entity_action_respawned": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "function jorigins:savecoords"
        },
        {
          "type": "origins:change_resource",
          "resource": "jorigins:return_liferesource",
          "change": 1
        }
      ]
    },
    "execute_chosen_when_orb": false
  },
  "returncooldown": {
    "type": "origins:cooldown",
    "cooldown": 2400,
    "hud_render": {
      "should_render": false,
      "bar_index": 3
    }
  },
  "recover": {
    "type": "origins:action_over_time",
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:change_resource",
          "resource": "jorigins:return_liferesource",
          "change": 1
        }
      ]
    },
    "interval": 20,
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:resource",
          "resource": "jorigins:return_returncooldown",
          "comparison": "<=",
          "compare_to": 10
        },
        {
          "type": "origins:resource",
          "resource": "jorigins:return_liferesource",
          "comparison": "==",
          "compare_to": 0
        }
      ]
    }
  },
  "shaking": {
    "type": "origins:shaking",
    "condition": {
      "type": "origins:resource",
      "resource": "jorigins:return_liferesource",
      "comparison": "==",
      "compare_to": 0
    }
  },
  "overlay_dead": {
    "type": "origins:overlay",
    "hidden": true,
    "sprite": "*:dirt",
    "strength": 0.4,
    "draw_mode": "texture",
    "draw_phase": "below_hud",
    "visible_in_third_person": false,
    "condition": {
      "type": "origins:resource",
      "resource": "jorigins:return_liferesource",
      "compare_to": 0,
      "comparison": "=="
    }
  },
  "prevent_flight": {
    "type": "origins:prevent_elytra_flight",
    "entity_action": {
      "type": "origins:execute_command",
      "command": "tellraw @s {\"text\": \"You cannot glide from this height!\", \"color\": \"red\"}"
    },
    "condition": {
      "type": "origins:resource",
      "resource": "jorigins:return_liferesource",
      "comparison": "==",
      "compare_to": 0
    }
  },
  "prevent_sprint": {
    "type": "origins:prevent_sprinting",
    "condition": {
      "type": "origins:resource",
      "resource": "jorigins:return_liferesource",
      "comparison": "==",
      "compare_to": 0
    }
  },
  "xpbottling": {
    "type": "origins:active_self",
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:add_xp",
          "points": -11
        },
        {
          "type": "origins:give",
          "stack": {
            "id": "minecraft:experience_bottle",
            "count": 1
          }
        }
      ]
    },
    "cooldown": 1,
    "hud_render": {
      "should_render": false
    },
    "key": {
      "key": "key.origins.secondary_active",
      "continuous": true
    },
    "condition": {
      "type": "origins:or",
      "conditions": [
        {
          "type": "origins:xp_points",
          "comparison": ">=",
          "compare_to": 11
        },
        {
          "type": "origins:xp_levels",
          "comparison": ">=",
          "compare_to": 1
        }
      ]
    },
    "hud_render": {
      "should_render": false
    }
  }
}
