{
  "name": "Sunlight Weakness",
  "description": "Standing in sunlight for long periods of time can cause you to ignite. Helmets slow the effect.",
  "type": "origins:multiple",
  "sunlight_change": {
    "type": "origins:action_over_time",
    "entity_action": {
      "type": "origins:if_else_list",
      "actions": [
        {
          "condition": {
            "type": "origins:equipped_item",
            "equipment_slot": "head",
            "item_condition": {
              "type": "origins:armor_value",
              "comparison": ">",
              "compare_to": 0
            },
            "inverted": true
          },
          "action": {
            "type": "origins:change_resource",
            "resource": "jorigins:sun/sunlight_resource_sunburn",
            "change": 2,
            "operation": "add"
          }
        },
        {
          "condition": {
            "type": "origins:equipped_item",
            "equipment_slot": "head",
            "item_condition": {
              "type": "origins:armor_value",
              "comparison": ">",
              "compare_to": 0
            },
            "inverted": false
          },
          "action": {
            "type": "origins:change_resource",
            "resource": "jorigins:sun/sunlight_resource_sunburn",
            "change": 1,
            "operation": "add"
          }
        }
      ]
    },
    "interval": 20,
    "condition": {
      "type": "origins:exposed_to_sun"
    }
  },
  "sunlight_decay": {
    "type": "origins:action_over_time",
    "entity_action": {
      "type": "origins:change_resource",
      "resource": "jorigins:sun/sunlight_resource_sunburn",
      "change": -1,
      "operation": "add"
    },
    "interval": 20,
    "condition": {
      "type": "origins:exposed_to_sun",
      "inverted": true
    }
  },
  "ignition": {
    "type": "origins:action_over_time",
    "entity_action": {
      "type": "origins:if_else_list",
      "actions": [
        {
          "condition": {
            "type": "origins:equipped_item",
            "equipment_slot": "head",
            "item_condition": {
              "type": "origins:armor_value",
              "comparison": ">",
              "compare_to": 0
            },
            "inverted": true
          },
          "action": {
            "type": "origins:set_on_fire",
            "duration": 2
          }
        },
        {
          "condition": {
            "type": "origins:equipped_item",
            "equipment_slot": "head",
            "item_condition": {
              "type": "origins:armor_value",
              "comparison": ">",
              "compare_to": 0
            },
            "inverted": false
          },
          "action": {
            "type": "origins:chance",
            "action": {
              "type": "origins:set_on_fire",
              "duration": 2
            },
            "chance": 0.3
          }
        }
      ]
    },
    "interval": 20,
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:resource",
          "resource": "jorigins:sun/sunlight_resource_sunburn",
          "comparison": ">=",
          "compare_to": 15
        },
        {
          "type": "origins:exposed_to_sun"
        }
      ]
    }
  },
  "clear": {
    "type": "origins:action_on_death",
    "bientity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:target_action",
          "action": {
            "type": "origins:execute_command",
            "command": "resource set @s jorigins:sun/sunlight_resource_exposure_level 0",
            "permission_level": 4
          }
        },
        {
          "type": "origins:target_action",
          "action": {
            "type": "origins:execute_command",
            "command": "resource set @s jorigins:sun/sunlight_resource_total_sunlight 0",
            "permission_level": 4
          }
        }
      ]
    }
  }
}
